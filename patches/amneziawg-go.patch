 	"runtime"
 	"sync"
 	"sync/atomic"
@@ -562,3 +565,27 @@ func (device *Device) BindClose() error {
 	device.net.Unlock()
 	return err
 }
+
+// CreateOutboundPacket creates and routes a packet to the appropriate peer
+func (device *Device) CreateOutboundPacket(payload []byte, dstIP net.IP) error {
+	peer := device.allowedips.Lookup(dstIP)
+	if peer == nil {
+		return fmt.Errorf("no peer found for IP %v", dstIP)
+	}
+	if !peer.isRunning.Load() {
+		return errors.New("peer not running")
+	}
+
+	elem := device.GetOutboundElement()
+	elem.buffer = device.GetMessageBuffer()
+
+	copy(elem.buffer[MessageTransportOffsetContent:], payload)
+	elem.packet = elem.buffer[MessageTransportOffsetContent : MessageTransportOffsetContent+len(payload)]
+
+	container := device.GetOutboundElementsContainer()
+	container.elems = append(container.elems, elem)
+
+	peer.StagePackets(container)
+	peer.SendStagedPackets()
+	return nil
+}
diff --git a/device/pool_size_netbird.go b/device/pool_size_netbird.go
new file mode 100644
index 0000000..00461af
--- /dev/null
+++ b/device/pool_size_netbird.go
@@ -0,0 +1,54 @@
+/* SPDX-License-Identifier: MIT
+ *
+ * NetBird AWG fork addition.
+ *
+ * Mirrors netbirdio/wireguard-go's device/pool_size.go so the NetBird client can
+ * tune buffer pools both before device creation (package-level setters) and on a
+ * live device (Device.SetPreallocatedBuffersPerPool). amneziawg-go's WaitPool has
+ * no dedicated `tracked` field, so SetMax follows amneziawg-go's own convention
+ * where a cap of zero means "uncapped/untracked".
+ */
+
+package device
+
+// MaxBatchSizeOverride exists for API parity with netbirdio/wireguard-go. amneziawg-go
+// has no batch-size override path, so setting it has no effect; the symbol is kept so
+// callers (e.g. the NetBird embeddable client) compile and run unchanged.
+var MaxBatchSizeOverride uint32 = 0
+
+// SetPreallocatedBuffersPerPool sets the global cap applied to the pools of Devices
+// created after this call. Zero disables the cap. To retune a live Device, use
+// Device.SetPreallocatedBuffersPerPool.
+func SetPreallocatedBuffersPerPool(n uint32) {
+	PreallocatedBuffersPerPool = n
+}
+
+// SetMaxBatchSizeOverride sets the global batch-size override. No-op in amneziawg-go
+// (see MaxBatchSizeOverride); kept for API parity.
+func SetMaxBatchSizeOverride(n uint32) {
+	MaxBatchSizeOverride = n
+}
+
+// SetMax updates the cap on this pool in place. Pools created uncapped
+// (PreallocatedBuffersPerPool == 0) stay on the untracked fast path and are left
+// unchanged; only already-capped pools (e.g. on mobile defaults) are retuned.
+func (p *WaitPool) SetMax(n uint32) {
+	p.lock.Lock()
+	defer p.lock.Unlock()
+	if p.max == 0 {
+		return
+	}
+	p.max = n
+	p.cond.Broadcast()
+}
+
+// SetPreallocatedBuffersPerPool updates the cap on this Device's pools in place.
+// Takes effect immediately; goroutines blocked in Get are unblocked if the cap was
+// raised. Has no effect on pools created with PreallocatedBuffersPerPool == 0.
+func (device *Device) SetPreallocatedBuffersPerPool(n uint32) {
+	device.pool.messageBuffers.SetMax(n)
+	device.pool.inboundElements.SetMax(n)
+	device.pool.outboundElements.SetMax(n)
+	device.pool.inboundElementsContainer.SetMax(n)
+	device.pool.outboundElementsContainer.SetMax(n)
+}
