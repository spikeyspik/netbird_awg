# Base upstream NetBird tag used for clone/patch/release.
NETBIRD_BASE_TAG=v0.66.1

# AWG release suffix. Final release/tag will be: <NETBIRD_BASE_TAG>-<AWG_VERSION_SUFFIX>
AWG_VERSION_SUFFIX=-awg-r1

# Upstream repositories.
NETBIRD_REPO=https://github.com/netbirdio/netbird.git
AWG_GO_REPO=https://github.com/amnezia-vpn/amneziawg-go.git
AWG_WINDOWS_REPO=https://github.com/amnezia-vpn/amneziawg-windows.git

# netbird-ui branding.
# Orange bird icon colors are replaced with this blue color.
UI_BRAND_COLOR_HEX=2EA3FF
# UI app/tray title branding.
UI_BRAND_NAME=NetBird AWG
# Optional explicit UI version label. Empty => "<UI_BRAND_NAME> <NETBIRD_RELEASE_TAG>".
UI_VERSION_LABEL=

# AWG dependency refs used for deterministic patching.
AWG_GO_REF=449d7cffd4adf86971bd679d0be5384b443e8be5
AWG_WINDOWS_REF=d70c30aecb955fd56c8be802d16f3215562f318d
